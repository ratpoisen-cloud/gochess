# Hashed assets — cache forever (content hash in filename)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets — 1 hour
/emojis/*
  Cache-Control: public, max-age=3600
/logo/*
  Cache-Control: public, max-age=3600
/sounds/*
  Cache-Control: public, max-age=3600
/pieces/*
  Cache-Control: public, max-age=3600

# Engine — cache
/engine/*
  Cache-Control: public, max-age=3600

# HTML — never cache
/*.html
  Cache-Control: no-cache
